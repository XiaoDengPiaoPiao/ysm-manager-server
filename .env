# RCON服务器配置
RCON_HOST=192.168.0.100
RCON_PORT=25575
RCON_PASSWORD=123456
# RCON命令执行超时时间（毫秒），如果在该时间内没有收到响应则认为执行失败
RCON_TIMEOUT=5000

# Token有效期（小时），默认为1小时
TOKEN_EXPIRE_HOURS=1

# 管理员密钥，用于重置用户密码等管理员操作
ADMIN_SECRET_KEY=123456

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./dev.db"
# 管理员账户密码
NULL_NAME_PASSWORD="123456"

# YSM模型文件存储目录
YSM_MODEL_DIR=/daemon/data/InstanceData/851a1911ff444b75995609748aace4d8/config/yes_steve_model

# 用户公共模型上传数量限制
CUSTOM_UPLOAD_LIMIT=5
# 用户私有模型上传数量限制
AUTH_UPLOAD_LIMIT=1
VERSION=0.0.1

# 定时模型重载间隔（毫秒），设置为0或不设置则禁用定时重载
RELOAD_TIME=30000000

# 上传模型后是否自动重载（true/false）
AUTO_RELOAD_ON_UPLOAD=true

# 绑定码有效期（分钟）
BINDING_EXPIRE_MINUTES=5