// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}
model test{
  id Int @id @default(autoincrement())
  name String
}
model User {
  id       Int     @id @default(autoincrement())
  name     String  @default("")
  password String  @default("")
  gameName String  @default("")
  token String?  @default("")
  tokenExpiresAt DateTime?
  customUploadLimit Int     @default(5)
  authUploadLimit   Int     @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // 关联关系
  uploadedModels ModelUploader[]
}

model Model {
  id           Int     @id @default(autoincrement())
  allowAuth    Boolean @default(false)
  currentType  String  @default("") // auth 或 custom
  hash         String  @default("")
  fileName     String  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // 关联关系
  uploaders    ModelUploader[]
  authorizations ModelAuthorization[]
}

model ModelUploader {
  id        Int     @id @default(autoincrement())
  modelId   Int
  userId    Int
  createdAt DateTime @default(now())
  
  // 关联关系
  model     Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 唯一约束，确保一个用户只能上传同一模型一次
  @@unique([modelId, userId])
}

model ModelAuthorization {
  id        Int     @id @default(autoincrement())
  gameName  String  @default("")
  modelId   Int
  createdAt DateTime @default(now())
  
  // 关联关系
  model     Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)
}